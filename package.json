{
  "name": "real-time-chess-battle-monorepo",
  "private": true,
  "scripts": {
    "dev:backend": "uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:all": "sh -c 'npm run dev:backend & npm run dev:frontend'",
    "build:frontend": "npm --prefix frontend run build",
    "build:all": "npm run build:frontend",
    "test:backend": "pytest -q",
    "test:frontend": "npm --prefix frontend run test",
    "test:all": "npm run test:backend && npm run test:frontend",
    "type:frontend": "npm --prefix frontend run typecheck",
    "lint:backend": "python -m py_compile app/**/*.py",
    "lint:frontend": "npm --prefix frontend run typecheck",
    "backend-flow": "pytest -q tests/test_backend_flow.py",
    "contracts:export": "python scripts/export_openapi.py",
    "contracts:generate": "bash scripts/generate_frontend_types.sh",
    "e2e": "echo \"Install Playwright first, then run e2e specs\" && exit 1",
    "e2e:headed": "echo \"Install Playwright first, then run headed e2e\" && exit 1"
  }
}
